# Copy to .env and adjust for your server, then run: docker compose up -d --build

# Container image to run. Leave unset for local builds (defaults to
# taskora-app:latest). The CI/CD pipeline injects the GHCR image automatically.
# APP_IMAGE=ghcr.io/khurramjamilsatti/taskora-app:latest

# Host ports the site is served on
HTTP_PORT=80
HTTPS_PORT=443

# Public URL of the deployment (used by Laravel)
APP_URL=http://your-server-ip
FRONTEND_URL=http://your-server-ip

# PostgreSQL credentials (shared by the postgres service and Laravel)
POSTGRES_DB=taskora
POSTGRES_USER=taskora
POSTGRES_PASSWORD=taskora_secret

# ---------------------------------------------------------------
# HTTPS / Let's Encrypt (Certbot)
# ---------------------------------------------------------------
# Requires a real domain whose DNS A record already points to this
# server, and ports 80 + 443 open. When enabled, set APP_URL and
# FRONTEND_URL to https://your-domain.
ENABLE_SSL=false
DOMAIN=
CERTBOT_EMAIL=
# Use Let's Encrypt staging while testing to avoid rate limits.
CERTBOT_STAGING=false
